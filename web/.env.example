# URL du serveur temps reel (Express + socket.io) deploye separement
# sur Railway / Fly.io / Render. En local, le serveur de server/ tourne
# par defaut sur http://localhost:3001.
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001

# Optionnel : URL publique de ce site (utile si tu veux generer des liens
# absolus cote serveur plus tard). Le lien de partage utilise deja
# window.location.origin cote client, cette variable n'est donc pas requise.
NEXT_PUBLIC_SITE_URL=https://ton-projet.vercel.app
